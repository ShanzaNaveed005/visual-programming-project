
@{
    ViewData["Title"] = "My Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var userId = Context.Session.GetInt32("UserId");
}

<div class="container py-4">
    <!-- Welcome Banner -->
    <div class="card bg-gradient-primary text-white mb-4 border-0 rounded-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
        <div class="card-body p-4">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h1 class="display-6 fw-bold">Welcome back, @Model.User.full_name! <i class="fas fa-smile-wink"></i></h1>
                    <p class="mb-0">Ready to plan your next adventure? Let's explore amazing destinations!</p>
                </div>
                <div class="col-md-4 text-end">
                    <a href="@Url.Action("PlanTrip", "Trips")" class="btn btn-light btn-lg">
                        <i class="fas fa-robot me-2"></i>Plan with AI
                    </a>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Stats Cards -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Total Trips</h6>
                            <h2 class="mb-0 fw-bold">@Model.TotalTrips</h2>
                        </div>
                        <div class="bg-primary bg-opacity-10 rounded-circle p-3">
                            <i class="fas fa-plane text-primary fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded