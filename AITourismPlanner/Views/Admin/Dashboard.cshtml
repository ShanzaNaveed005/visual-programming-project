@model AITourismPlanner.Controllers.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var adminName = ViewBag.AdminName ?? "Admin";
}

<div class="container-fluid py-4">
    <!-- Welcome Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card bg-gradient-primary text-white border-0 rounded-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                <div class="card-body p-4">
                    <h1 class="display-5 fw-bold">
                        <i class="fas fa-crown me-2"></i> Welcome, @adminName!
                    </h1>
                    <p class="mb-0">Here's what's happening with your platform today.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Total Users</h6>
                            <h2 class="mb-0 fw-bold">@Model.TotalUsers</h2>
                            <small class="text-success">@Model.TotalCustomers Customers</small>
                        </div>
                        <div class="bg-primary bg-opacity-10 rounded-circle p-3">
                            <i class="fas fa-users text-primary fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Destinations</h6>
                            <h2 class="mb-0 fw-bold">@Model.TotalDestinations</h2>
                            <small class="text-muted">+@Model.TotalHotels Hotels</small>
                        </div>
                        <div class="bg-success bg-opacity-10 rounded-circle p-3">
                            <i class="fas fa-map-marked-alt text-success fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Total Bookings</h6>
                            <h2 class="mb-0 fw-bold">@Model.TotalBookings</h2>
                            <small class="text-warning">@Model.PendingBookings Pending</small>
                        </div>
                        <div class="bg-warning bg-opacity-10 rounded-circle p-3">
                            <i class="fas fa-hotel text-warning fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Total Revenue</h6>
                            <h2 class="mb-0 fw-bold">PKR @Model.TotalRevenue.ToString("N0")</h2>
                            <small class="text-info">Lifetime earnings</small>
                        </div>
                        <div class="bg-info bg-opacity-10 rounded-circle p-3">
                            <i class="fas fa-rupee-sign text-info fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Bookings & Popular Destinations -->
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-0 pt-4">
                    <h5 class="fw-bold mb-0">
                        <i class="fas fa-clock text-primary me-2"></i> Recent Bookings
                    </h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>User</th>
                                    <th>Hotel</th>
                                    <th>Check In</th>
                                    <th>Amount</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var booking in Model.RecentBookings)
                                {
                                    <tr>
                                        <td>@(booking.User?.full_name ?? "N/A")</td>
                                        <td>@(booking.Hotel?.hotel_name ?? "N/A")</td>
                                        <td>@booking.check_in?.ToString("dd MMM")</td>
                                        <td>PKR @booking.total_amount?.ToString("N0")</td>
                                        <td>
                                            <span class="badge @(booking.booking_status == "Confirmed" ? "bg-success" : booking.booking_status == "Pending" ? "bg-warning" : "bg-danger")">
                                                @booking.booking_status
                                            </span>
                                         </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white border-0 pt-4">
                    <h5 class="fw-bold mb-0">
                        <i class="fas fa-fire text-primary me-2"></i> Popular Destinations
                    </h5>
                </div>
                <div class="card-body">
                    @foreach (var dest in Model.PopularDestinations)
                    {
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div>
                                <h6 class="mb-0">@dest.name</h6>
                                <small class="text-muted">@dest.city</small>
                            </div>
                            <div class="text-warning">
                                @for (int i = 1; i <= (int)dest.rating_average; i++)
                                {
                                    <i class="fas fa-star small"></i>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-0 pt-4">
                    <h5 class="fw-bold mb-0">
                        <i class="fas fa-comment text-primary me-2"></i> Recent Feedback
                    </h5>
                </div>
                <div class="card-body">
                    @foreach (var review in Model.RecentFeedbacks)
                    {
                        <div class="border-bottom pb-2 mb-2">
                            <p class="mb-1 small">"@(review.review_text?.Length > 60 ? review.review_text.Substring(0, 60) + "..." : review.review_text)"</p>
                            <small class="text-muted">- @(review.User?.full_name ?? "Anonymous")</small>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-0 pt-4">
                    <h5 class="fw-bold mb-0">
                        <i class="fas fa-bolt text-primary me-2"></i> Quick Actions
                    </h5>
                </div>
                <div class="card-body">
                    <div class="d-flex gap-3 flex-wrap">
                        <a href="@Url.Action("AddDestination", "Admin")" class="btn btn-primary">
                            <i class="fas fa-plus"></i> Add Destination
                        </a>
                        <a href="@Url.Action("AddHotel", "Admin")" class="btn btn-success">
                            <i class="fas fa-hotel"></i> Add Hotel
                        </a>
                        <a href="@Url.Action("Users", "Admin")" class="btn btn-info">
                            <i class="fas fa-users"></i> Manage Users
                        </a>
                        <a href="@Url.Action("Reports", "Admin")" class="btn btn-warning">
                            <i class="fas fa-chart-bar"></i> View Reports
                        </a>
                        <a href="@Url.Action("Logs", "Admin")" class="btn btn-secondary">
                            <i class="fas fa-history"></i> Admin Logs
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-gradient-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }
    .card {
        transition: transform 0.2s ease;
    }
    .card:hover {
        transform: translateY(-3px);
    }
    .btn {
        transition: all 0.3s ease;
    }
    .btn:hover {
        transform: translateY(-2px);
    }
</style>