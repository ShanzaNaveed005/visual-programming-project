@model List<AITourismPlanner.Models.DestinationApiModel>
@{
    ViewData["Title"] = "Explore Destinations";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var categories = ViewBag.Categories as string[];
    var selectedCategory = ViewBag.SelectedCategory as string;
}

<div class="container py-4">
    <!-- Header -->
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">
            <i class="fas fa-map-marked-alt text-primary"></i> Explore Destinations
        </h1>
        <p class="lead">Discover the most beautiful places in Pakistan</p>
    </div>

    <!-- Search Bar -->
    <div class="row justify-content-center mb-5">
        <div class="col-md-8">
            <div class="search-container">
                <div class="input-group input-group-lg shadow-sm">
                    <input type="text" id="searchInput" class="form-control border-0" placeholder="Search destinations... (e.g., Hunza, Murree, Skardu)" autocomplete="off">
                    <button class="btn btn-primary px-4" onclick="searchDestination()">
                        <i class="fas fa-search"></i> Search
                    </button>
                </div>
                <div id="autocompleteResults" class="autocomplete-dropdown"></div>
            </div>
        </div>
    </div>

    <!-- Category Filters -->
    <div class="category-filters mb-5">
        <div class="d-flex flex-wrap justify-content-center gap-2">
            @foreach (var cat in categories)
            {
                if (cat == "All")
                {
                    <a href="@Url.Action("Index", new { category = cat == "All" ? null : cat })" 
                       class="btn @(string.IsNullOrEmpty(selectedCategory) || selectedCategory == "All" ? "btn-primary" : "btn-outline-secondary") rounded-pill px-4">
                        @cat
                    </a>
                }
                else
                {
                    <a href="@Url.Action("Index", new { category = cat })" 
                       class="btn @(selectedCategory == cat ? "btn-primary" : "btn-outline-secondary") rounded-pill px-4">
                        @cat
                    </a>
                }
            }
        </div>
    </div>

    <!-- Results Count -->
    <div class="mb-4">
        <p class="text-muted">Found <strong>@Model.Count</strong> destinations</p>
    </div>

    <!-- Destinations Grid -->
    @if (Model.Any())
    {
        <div class="row g-4">
            @foreach (var dest in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card destination-card h-100 shadow-sm border-0 rounded-4 overflow-hidden">
                        <div class="position-relative">
                            <img src="@dest.ImageUrl" class="card-img-top" style="height: 220px; object-fit: cover;" alt="@dest.Name">
                            <div class="position-absolute top-0 end-0 m-3">
                                <span class="badge bg-warning text-dark px-3 py-2 rounded-pill">
                                    <i class="fas fa-star text-warning"></i> @dest.Rating.ToString("0.0")
                                </span>
                            </div>
                            <div class="position-absolute bottom-0 start-0 m-3">
                                <span class="badge bg-primary px-3 py-2 rounded-pill">
                                    @dest.Category
                                </span>
                            </div>
                        </div>
                        <div class="card-body p-4">
                            <h5 class="card-title fw-bold">@dest.Name</h5>
                            <p class="text-muted small">
                                <i class="fas fa-map-marker-alt text-primary"></i> @dest.City, @dest.State
                            </p>
                            <p class="card-text small">@(dest.Description.Length > 100 ? dest.Description.Substring(0, 100) + "..." : dest.Description)</p>
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <span class="text-primary fw-bold fs-5">PKR @dest.EstimatedCost.ToString("N0")</span>
                                <span class="text-muted"><i class="fas fa-clock"></i> @dest.BestTimeToVisit.Split('(')[0].Trim()</span>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent border-0 pb-4 px-4">
                            <a href="@Url.Action("Details", new { name = dest.Name })" class="btn btn-outline-primary w-100">
                                View Details <i class="fas fa-arrow-right ms-2"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="fas fa-map-marked-alt fa-4x text-muted mb-3"></i>
            <h3>No destinations found</h3>
            <p>Try a different category or search term</p>
            <a href="@Url.Action("Index")" class="btn btn-primary">View All Destinations</a>
        </div>
    }
</div>

<style>
    .destination-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .destination-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.1) !important;
    }
    .search-container {
        position: relative;
    }
    .autocomplete-dropdown {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: white;
        border-radius: 10px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
        z-index: 1000;
        display: none;
        max-height: 300px;
        overflow-y: auto;
    }
    .autocomplete-item {
        padding: 12px 20px;
        cursor: pointer;
        border-bottom: 1px solid #eee;
        transition: background 0.2s;
    }
    .autocomplete-item:hover {
        background: #f8f9fa;
    }
    .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
    }
    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 20px rgba(102,126,234,0.4);
    }
    .category-filters .btn {
        transition: all 0.3s ease;
    }
    .category-filters .btn:hover {
        transform: translateY(-2px);
    }
</style>

<script>
    // Autocomplete
    $('#searchInput').on('input', function() {
        var term = $(this).val();
        if (term.length > 1) {
            $.ajax({
                url: '@Url.Action("Autocomplete", "Destination")',
                type: 'GET',
                data: { term: term },
                success: function(data) {
                    var dropdown = $('#autocompleteResults');
                    dropdown.empty().show();
                    if (data.length > 0) {
                        data.forEach(function(item) {
                            dropdown.append('<div class="autocomplete-item" onclick="selectDestination(\'' + item + '\')">' + item + '</div>');
                        });
                    } else {
                        dropdown.append('<div class="autocomplete-item text-muted">No results found</div>');
                    }
                }
            });
        } else {
            $('#autocompleteResults').hide();
        }
    });

    $(document).click(function(e) {
        if (!$(e.target).closest('.search-container').length) {
            $('#autocompleteResults').hide();
        }
    });

    function selectDestination(name) {
        $('#searchInput').val(name);
        $('#autocompleteResults').hide();
        window.location.href = '@Url.Action("Details", "Destination")?name=' + encodeURIComponent(name);
    }

    function searchDestination() {
        var query = $('#searchInput').val();
        if (query) {
            window.location.href = '@Url.Action("Search", "Destination")?q=' + encodeURIComponent(query);
        }
    }
</script>