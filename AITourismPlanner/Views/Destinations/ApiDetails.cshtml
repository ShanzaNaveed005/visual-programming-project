@model AITourismPlanner.ViewModels.ApiDestinationViewModel
@{
    ViewData["Title"] = Model.CityName;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var userId = Context.Session.GetInt32("UserId");
}

<div class="container py-4">

    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Home")">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Destinations")">Destinations</a>
            </li>
            <li class="breadcrumb-item active">@Model.CityName</li>
        </ol>
    </nav>

    <!-- Hero -->
    <div class="card border-0 rounded-4 overflow-hidden shadow-lg mb-5"
         style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 280px;">
        <div class="card-body p-5 text-white">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h1 class="display-4 fw-bold">@Model.CityName</h1>
                    <p class="fs-5">
                        <i class="fas fa-map-marker-alt me-2"></i>
                        @Model.DestinationInfo?.Country
                    </p>
                    @if (Model.DestinationInfo != null)
                    {
                        <p>
                            <i class="fas fa-users me-2"></i>
                            Population: @Model.DestinationInfo.Population.ToString("N0")
                        </p>
                    }
                </div>
                <div class="col-md-4 text-end">
                    @if (Model.CurrentWeather != null)
                    {
                        <div class="bg-white bg-opacity-25 rounded-4 p-3 d-inline-block">
                            <img src="@Model.CurrentWeather.Icon" style="width:60px;">
                            <h3 class="mb-0">
                                @Model.CurrentWeather.Temperature.ToString("0")°C
                            </h3>
                            <p class="mb-0">@Model.CurrentWeather.Condition</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">

            <!-- Map -->
            @if (Model.DestinationInfo != null)
            {
                <div class="card border-0 shadow-sm rounded-4 mb-4">
                    <div class="card-body p-4">
                        <h3 class="fw-bold mb-3">
                            <i class="fas fa-map text-primary me-2"></i>Location Map
                        </h3>
                        <div id="map" style="height:300px; border-radius:12px;"></div>
                    </div>
                </div>
            }

            <!-- Attractions -->
            @if (Model.DestinationInfo?.Attractions != null &&
                             Model.DestinationInfo.Attractions.Any())
            {
                <div class="card border-0 shadow-sm rounded-4 mb-4">
                    <div class="card-body p-4">
                        <h3 class="fw-bold mb-4">
                            <i class="fas fa-landmark text-primary me-2"></i>
                            Top Attractions
                        </h3>
                        <div class="row g-3">
                            @foreach (var place in Model.DestinationInfo.Attractions)
                            {
                                <div class="col-md-6">
                                    <div class="d-flex align-items-center
                                        p-3 bg-light rounded-3">
                                        <div class="bg-primary rounded-circle me-3"
                                             style="min-width:40px; height:40px;
                                            display:flex; align-items:center;
                                            justify-content:center;">
                                            <i class="fas fa-map-marker-alt text-white"></i>
                                        </div>
                                        <div>
                                            <h6 class="mb-0 fw-bold">@place.Name</h6>
                                            <small class="text-muted">
                                                @((place.Distance / 1000).ToString("0.1")) km away
                                            </small>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

            <!-- Weather Forecast -->
            @if (Model.Forecast?.DailyForecasts != null &&
                             Model.Forecast.DailyForecasts.Any())
            {
                <div class="card border-0 shadow-sm rounded-4 mb-4">
                    <div class="card-body p-4">
                        <h3 class="fw-bold mb-4">
                            <i class="fas fa-cloud-sun text-primary me-2"></i>
                            5-Day Forecast
                        </h3>
                        <div class="row g-3">
                            @foreach (var day in Model.Forecast.DailyForecasts.Take(5))
                            {
                                <div class="col">
                                    <div class="card border-0 bg-light rounded-4
                                        text-center p-3">
                                        <small class="fw-bold">
                                            @day.Date.ToString("ddd")
                                        </small>
                                        <img src="@day.Icon"
                                             style="width:40px;" class="mx-auto my-2">
                                        <h6 class="mb-0">
                                            @day.TempMax.ToString("0")°
                                        </h6>
                                        <small class="text-muted">
                                            @day.TempMin.ToString("0")°
                                        </small>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

            <!-- Hotels -->
            @if (Model.NearbyHotels.Any())
            {
                <div class="card border-0 shadow-sm rounded-4 mb-4">
                    <div class="card-body p-4">
                        <h3 class="fw-bold mb-4">
                            <i class="fas fa-hotel text-primary me-2"></i>
                            Nearby Hotels
                        </h3>
                        <div class="row g-4">
                            @foreach (var hotel in Model.NearbyHotels.Take(4))
                            {
                                <div class="col-md-6">
                                    <div class="card border-0 shadow-sm rounded-4 h-100">
                                        @if (!string.IsNullOrEmpty(hotel.ImageUrl))
                                        {
                                            <img src="@hotel.ImageUrl"
                                                 class="card-img-top rounded-top-4"
                                                 style="height:150px; object-fit:cover;">
                                        }
                                        else
                                        {
                                            <div class="rounded-top-4"
                                                 style="height:150px;
                                                background:linear-gradient(135deg,#f093fb,#f5576c);
                                                display:flex; align-items:center;
                                                justify-content:center;">
                                                <i class="fas fa-hotel fa-3x text-white"></i>
                                            </div>
                                        }
                                        <div class="card-body p-3">
                                            <h6 class="fw-bold">@hotel.Name</h6>
                                            @if (hotel.Rating.HasValue)
                                            {
                                                <span class="badge bg-warning text-dark">
                                                    <i class="fas fa-star"></i>
                                                    @hotel.Rating?.ToString("0.0")
                                                </span>
                                            }
                                            @if (hotel.PricePerNight.HasValue)
                                            {
                                                <p class="text-primary fw-bold mt-2 mb-0">
                                                    PKR @hotel.PricePerNight?.ToString("N0")
                                                    <span class="text-muted fw-normal">/night</span>
                                                </p>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Right Sidebar -->
        <div class="col-lg-4">

            <!-- Quick Info -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-3">Quick Info</h4>
                    @if (Model.DestinationInfo != null)
                    {
                        <p>
                            <i class="fas fa-globe text-primary me-2"></i>
                            Country: <strong>@Model.DestinationInfo.Country</strong>
                        </p>
                        <p>
                            <i class="fas fa-users text-primary me-2"></i>
                            Population:
                            <strong>
                                @Model.DestinationInfo.Population.ToString("N0")
                            </strong>
                        </p>
                        <p>
                            <i class="fas fa-landmark text-primary me-2"></i>
                            Attractions:
                            <strong>
                                @Model.DestinationInfo.Attractions?.Count
                            </strong>
                        </p>
                    }
                    <a href="@Url.Action("PlanTrip", "Trips")"
                           class="btn btn-primary w-100 mt-2">
                        <i class="fas fa-robot me-2"></i> Plan with AI
                    </a>
                </div>
            </div>

            <!-- Weather Card -->
            @if (Model.CurrentWeather != null)
            {
                <div class="card border-0 shadow-sm rounded-4"
                     style="background:linear-gradient(135deg,#4facfe,#00f2fe);">
                    <div class="card-body p-4 text-white">
                        <h4 class="fw-bold">
                            <i class="fas fa-cloud-sun me-2"></i>Weather
                        </h4>
                        <div class="d-flex align-items-center">
                            <img src="@Model.CurrentWeather.Icon" style="width:70px;">
                            <div class="ms-3">
                                <h2 class="mb-0">
                                    @Model.CurrentWeather.Temperature.ToString("0")°C
                                </h2>
                                <p class="mb-0">@Model.CurrentWeather.Condition</p>
                            </div>
                        </div>
                        <hr class="border-white">
                        <div class="row text-center">
                            <div class="col-4">
                                <i class="fas fa-tint"></i>
                                <p class="mb-0 small">@Model.CurrentWeather.Humidity%</p>
                                <small>Humidity</small>
                            </div>
                            <div class="col-4">
                                <i class="fas fa-wind"></i>
                                <p class="mb-0 small">
                                    @Model.CurrentWeather.WindSpeed km/h
                                </p>
                                <small>Wind</small>
                            </div>
                            <div class="col-4">
                                <i class="fas fa-thermometer-half"></i>
                                <p class="mb-0 small">
                                    @Model.CurrentWeather.FeelsLike.ToString("0")°
                                </p>
                                <small>Feels Like</small>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<link rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

@section Scripts {
    <script>
        @if (Model.DestinationInfo != null)
        {
            <text>
                var map = L.map('map').setView(
                [@Model.DestinationInfo.Lat, @Model.DestinationInfo.Lon], 12);
                L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '© OpenStreetMap'
                }).addTo(map);
                L.marker([@Model.DestinationInfo.Lat, @Model.DestinationInfo.Lon])
                .addTo(map)
                .bindPopup('@Model.CityName')
                .openPopup();
            </text>
        }
    </script>
}