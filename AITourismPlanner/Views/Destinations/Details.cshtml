@model AITourismPlanner.ViewModels.DestinationDetailViewModel
@{
    ViewData["Title"] = Model.Destination.name;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var userId = Context.Session.GetInt32("UserId");
}

<div class="container py-4">

    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Home")">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Destinations")">Destinations</a>
            </li>
            <li class="breadcrumb-item active">@Model.Destination.name</li>
        </ol>
    </nav>

    <!-- Hero Section -->
    <div class="card border-0 rounded-4 overflow-hidden shadow-lg mb-5"
         style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 300px;">
        <div class="card-body p-5 text-white d-flex align-items-center">
            <div class="row w-100 align-items-center">
                <div class="col-md-8">
                    <h1 class="display-4 fw-bold">@Model.Destination.name</h1>
                    <p class="fs-5">
                        <i class="fas fa-map-marker-alt me-2"></i>
                        @Model.Destination.city, @Model.Destination.country
                    </p>
                    <div class="mb-3">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <i class="fas fa-star @(i <= (int)Model.Destination.rating_average
                                                               ? "text-warning" : "text-white-50")"></i>
                    }
                    <span class="ms-2">
                        @Model.Destination.rating_average.ToString("0.0")
                        (@Model.Reviews.Count reviews)
                    </span>
                </div>
                <span class="badge bg-light text-dark fs-6 px-3 py-2">
                    @Model.Destination.Category?.category_name
                </span>
            </div>
            <div class="col-md-4 text-end">
                @if (Model.CurrentWeather != null)
                {
                    <div class="bg-white bg-opacity-25 rounded-4 p-3 d-inline-block">
                        <img src="@Model.CurrentWeather.Icon" style="width:60px;">
                        <h3 class="mb-0">@Model.CurrentWeather.Temperature.ToString("0")°C</h3>
                        <p class="mb-0">@Model.CurrentWeather.Condition</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Left Column -->
    <div class="col-lg-8">

        <!-- About Section -->
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-body p-4">
                <h3 class="fw-bold mb-3">
                    <i class="fas fa-info-circle text-primary me-2"></i>About
                </h3>
                <p class="fs-5">@Model.Destination.description</p>
                @if (Model.DestinationInfo != null)
                {
                    <div class="row mt-3">
                        <div class="col-md-4 text-center">
                            <i class="fas fa-users fa-2x text-primary mb-2"></i>
                            <p class="mb-0 fw-bold">
                                @Model.DestinationInfo.Population.ToString("N0")
                            </p>
                            <small class="text-muted">Population</small>
                        </div>
                        <div class="col-md-4 text-center">
                            <i class="fas fa-map-pin fa-2x text-primary mb-2"></i>
                            <p class="mb-0 fw-bold">
                                @Model.DestinationInfo.Lat.ToString("0.00"),
                                @Model.DestinationInfo.Lon.ToString("0.00")
                            </p>
                            <small class="text-muted">Coordinates</small>
                        </div>
                        <div class="col-md-4 text-center">
                            <i class="fas fa-calendar fa-2x text-primary mb-2"></i>
                            <p class="mb-0 fw-bold">@Model.Destination.best_season</p>
                            <small class="text-muted">Best Season</small>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Map Section -->
        @if (Model.DestinationInfo != null)
        {
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h3 class="fw-bold mb-3">
                        <i class="fas fa-map text-primary me-2"></i>Location
                    </h3>
                    <div id="map" style="height: 300px; border-radius: 12px;"></div>
                </div>
            </div>
        }

        <!-- Nearby Attractions -->
        @if (Model.DestinationInfo?.Attractions != null &&
             Model.DestinationInfo.Attractions.Any())
        {
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h3 class="fw-bold mb-4">
                        <i class="fas fa-landmark text-primary me-2"></i>
                        Nearby Attractions
                    </h3>
                    <div class="row g-3">
                        @foreach (var place in Model.DestinationInfo.Attractions.Take(6))
                        {
                            <div class="col-md-6">
                                <div class="d-flex align-items-center p-3 bg-light rounded-3">
                                    <div class="bg-primary rounded-circle p-2 me-3"
                                         style="min-width:40px; height:40px;
                                        display:flex; align-items:center;
                                        justify-content:center;">
                                        <i class="fas fa-map-marker-alt text-white"></i>
                                    </div>
                                    <div>
                                        <h6 class="mb-0 fw-bold">@place.Name</h6>
                                        <small class="text-muted">
                                            @(place.Distance / 1000).ToString("0.0") km away
                                        </small>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- Weather Forecast -->
        @if (Model.Forecast?.DailyForecasts != null &&
             Model.Forecast.DailyForecasts.Any())
        {
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h3 class="fw-bold mb-4">
                        <i class="fas fa-cloud-sun text-primary me-2"></i>
                        5-Day Weather Forecast
                    </h3>
                    <div class="row g-3">
                        @foreach (var day in Model.Forecast.DailyForecasts.Take(5))
                        {
                            <div class="col">
                                <div class="card border-0 bg-light rounded-4 text-center p-3">
                                    <small class="fw-bold">
                                        @day.Date.ToString("ddd")
                                    </small>
                                    <img src="@day.Icon" style="width:40px;"
                                         class="mx-auto my-2">
                                    <h6 class="mb-0">
                                        @day.TempMax.ToString("0")°
                                    </h6>
                                    <small class="text-muted">
                                        @day.TempMin.ToString("0")°
                                    </small>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- Nearby Hotels -->
        @if (Model.NearbyHotels != null && Model.NearbyHotels.Any())
        {
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h3 class="fw-bold mb-4">
                        <i class="fas fa-hotel text-primary me-2"></i>
                        Nearby Hotels
                    </h3>
                    <div class="row g-4">
                        @foreach (var hotel in Model.NearbyHotels.Take(4))
                        {
                            <div class="col-md-6">
                                <div class="card border-0 shadow-sm rounded-4 h-100">
                                    @if (!string.IsNullOrEmpty(hotel.ImageUrl))
                                    {
                                        <img src="@hotel.ImageUrl"
                                             class="card-img-top rounded-top-4"
                                             style="height:150px; object-fit:cover;">
                                    }
                                    else
                                    {
                                        <div class="rounded-top-4"
                                             style="height:150px;
                                            background: linear-gradient(135deg,#f093fb,#f5576c);
                                            display:flex; align-items:center;
                                            justify-content:center;">
                                            <i class="fas fa-hotel fa-3x text-white"></i>
                                        </div>
                                    }
                                    <div class="card-body p-3">
                                        <h6 class="fw-bold">@hotel.Name</h6>
                                        @if (hotel.Rating.HasValue)
                                        {
                                            <span class="badge bg-warning text-dark">
                                                <i class="fas fa-star"></i>
                                                @hotel.Rating?.ToString("0.0")
                                            </span>
                                        }
                                        @if (hotel.PricePerNight.HasValue)
                                        {
                                            <p class="text-primary fw-bold mt-2 mb-0">
                                                PKR @hotel.PricePerNight?.ToString("N0")
                                                <span class="text-muted fw-normal">/night</span>
                                            </p>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- Reviews Section -->
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-body p-4">
                <h3 class="fw-bold mb-4">
                    <i class="fas fa-star text-primary me-2"></i>
                    Reviews (@Model.Reviews.Count)
                </h3>

                @if (userId.HasValue)
                {
                    <div class="card bg-light border-0 rounded-4 p-4 mb-4">
                        <h5 class="fw-bold">Write a Review</h5>
                        <div class="mb-3">
                            <div class="star-rating" id="starRating">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="far fa-star fa-2x"
                                       data-rating="@i"
                                       style="cursor:pointer; color:#ddd; margin-right:5px;"></i>
                                }
                            </div>
                            <input type="hidden" id="selectedRating" value="0">
                        </div>
                        <textarea id="reviewComment" class="form-control mb-3"
                                  rows="3"
                                  placeholder="Share your experience..."></textarea>
                        <button onclick="submitReview(@Model.Destination.destination_id)"
                                class="btn btn-primary">
                            Submit Review
                        </button>
                    </div>
                }
                else
                {
                    <div class="alert alert-info">
                        <a href="@Url.Action("Login", "Account")">Login</a>
                        to write a review
                    </div>
                }

                @if (Model.Reviews.Any())
                {
                    @foreach (var review in Model.Reviews
                        .OrderByDescending(r => r.review_date))
                    {
                        <div class="card border-0 shadow-sm rounded-4 mb-3">
                            <div class="card-body p-4">
                                <div class="d-flex align-items-center mb-2">
                                    <div class="bg-primary rounded-circle text-white
                                        d-flex align-items-center
                                        justify-content-center me-3"
                                         style="width:45px; height:45px;">
                                        <span class="fw-bold">
                                            @(review.User?.full_name?.FirstOrDefault()
                                                .ToString() ?? "U")
                                        </span>
                                    </div>
                                    <div>
                                        <h6 class="mb-0 fw-bold">
                                            @(review.User?.full_name ?? "Anonymous")
                                        </h6>
                                        <small class="text-muted">
                                            @review.review_date.ToString("dd MMM yyyy")
                                        </small>
                                    </div>
                                    <div class="ms-auto">
                                        @for (int i = 1; i <= (review.rating ?? 0); i++)
                                        {
                                            <i class="fas fa-star text-warning"></i>
                                        }
                                    </div>
                                </div>
                                <p class="mb-0">@review.review_text</p>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-4">
                        <i class="fas fa-comment-dots fa-3x text-muted mb-3"></i>
                        <p>No reviews yet. Be the first!</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Right Column -->
    <div class="col-lg-4">

        <!-- Trip Info Card -->
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-body p-4">
                <h4 class="fw-bold mb-3">Trip Info</h4>
                <table class="table table-borderless">
                    <tr>
                        <td class="text-muted">Estimated Cost</td>
                        <td class="fw-bold text-primary">
                            PKR @Model.Destination.estimated_cost?.ToString("N0")
                        </td>
                    </tr>
                    <tr>
                        <td class="text-muted">Best Season</td>
                        <td class="fw-bold">@Model.Destination.best_season</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Category</td>
                        <td class="fw-bold">
                            @Model.Destination.Category?.category_name
                        </td>
                    </tr>
                </table>
                <a href="@Url.Action("PlanTrip", "Trips",
                                           new { destinationId = Model.Destination.destination_id })"
                   class="btn btn-primary w-100 mt-2">
                    <i class="fas fa-robot me-2"></i> Plan with AI
                </a>
                @if (userId.HasValue)
                {
                    <button onclick="toggleFavorite(@Model.Destination.destination_id)"
                            class="btn btn-outline-danger w-100 mt-2" id="favBtn">
                        <i class="far fa-heart me-2"></i> Save to Wishlist
                    </button>
                }
            </div>
        </div>

        <!-- Current Weather Card -->
        @if (Model.CurrentWeather != null)
        {
            <div class="card border-0 shadow-sm rounded-4 mb-4"
                 style="background: linear-gradient(135deg, #4facfe, #00f2fe);">
                <div class="card-body p-4 text-white">
                    <h4 class="fw-bold">
                        <i class="fas fa-cloud-sun me-2"></i>Current Weather
                    </h4>
                    <div class="d-flex align-items-center">
                        <img src="@Model.CurrentWeather.Icon" style="width:70px;">
                        <div class="ms-3">
                            <h2 class="mb-0">
                                @Model.CurrentWeather.Temperature.ToString("0")°C
                            </h2>
                            <p class="mb-0">@Model.CurrentWeather.Condition</p>
                        </div>
                    </div>
                    <hr class="border-white">
                    <div class="row text-center">
                        <div class="col-4">
                            <i class="fas fa-tint"></i>
                            <p class="mb-0 small">@Model.CurrentWeather.Humidity%</p>
                            <small>Humidity</small>
                        </div>
                        <div class="col-4">
                            <i class="fas fa-wind"></i>
                            <p class="mb-0 small">
                                @Model.CurrentWeather.WindSpeed km/h
                            </p>
                            <small>Wind</small>
                        </div>
                        <div class="col-4">
                            <i class="fas fa-thermometer-half"></i>
                            <p class="mb-0 small">
                                @Model.CurrentWeather.FeelsLike.ToString("0")°
                            </p>
                            <small>Feels Like</small>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
</div>

<!-- Leaflet Map -->
<link rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

@section Scripts {
    <script>
        @if (Model.DestinationInfo != null)
        {
            <text>
                var map = L.map('map').setView(
                [@Model.DestinationInfo.Lat, @Model.DestinationInfo.Lon], 13);
                L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '© OpenStreetMap'
                }).addTo(map);
                L.marker([@Model.DestinationInfo.Lat, @Model.DestinationInfo.Lon])
                .addTo(map)
                .bindPopup('@Model.Destination.name')
                .openPopup();
            </text>
        }

        // Star Rating
        document.querySelectorAll('#starRating i').forEach(function(star) {
        star.addEventListener('click', function() {
        var rating = this.getAttribute('data-rating');
        document.getElementById('selectedRating').value = rating;
        document.querySelectorAll('#starRating i').forEach(function(s) {
        var r = s.getAttribute('data-rating');
        s.className = r <= rating
        ? 'fas fa-star fa-2x'
        : 'far fa-star fa-2x';
        s.style.color = r <= rating ? '#ffc107' : '#ddd';
        });
        });
        });

        function submitReview(destId) {
        var rating = document.getElementById('selectedRating').value;
        var comment = document.getElementById('reviewComment').value;
        if (rating == 0) { alert('Please select rating'); return; }
        if (!comment) { alert('Please write a review'); return; }

        fetch('@Url.Action("AddReview", "Destinations")', {
        method: 'POST',
        headers: {
        'Content-Type': 'application/x-www-form-urlencoded',
        'RequestVerificationToken': document.querySelector(
        'input[name="__RequestVerificationToken"]')?.value ?? ''
        },
        body: `destinationId=${destId}&rating=${rating}&comment=${encodeURIComponent(comment)}`
        })
        .then(r => r.json())
        .then(data => {
        alert(data.message);
        if (data.success) location.reload();
        });
        }

        function toggleFavorite(destId) {
        fetch('@Url.Action("ToggleFavorite", "Account")', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: `destinationId=${destId}`
        })
        .then(r => r.json())
        .then(data => { alert(data.message); });
        }
    </script>
}