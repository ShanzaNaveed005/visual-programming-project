@model List<AITourismPlanner.Services.DestinationInfo>
@{
    ViewData["Title"] = "Explore Destinations";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <!-- Header -->
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Explore Destinations</h1>
        <p class="lead text-muted">Discover amazing places in Pakistan</p>
    </div>

    <!-- Search -->
    <div class="card shadow-sm border-0 rounded-4 mb-5">
        <div class="card-body p-4">
            <form method="get" class="row g-3">
                <div class="col-md-10">
                    <input type="text" name="searchTerm"
                           class="form-control form-control-lg"
                           placeholder="Search any city e.g. Lahore, Hunza, Swat..."
                           value="@ViewBag.SearchTerm">
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary btn-lg w-100">
                        <i class="fas fa-search"></i> Search
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Results -->
    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var dest in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0 rounded-4">
                        <!-- IMAGE - Direct Unsplash URL -->
                        <img src="https://source.unsplash.com/featured/600x400/?@dest.Name,travel"
                             class="card-img-top rounded-top-4"
                             style="height: 200px; object-fit: cover;"
                             alt="@dest.Name"
                             onerror="this.src='https://source.unsplash.com/featured/600x400/?travel'">
                        <div class="card-body">
                            <h5 class="card-title fw-bold">@dest.Name</h5>
                            <p class="text-muted small mb-2">
                                <i class="fas fa-users me-1"></i>
                                Population: @dest.Population.ToString("N0")
                            </p>
                            <p class="text-muted small mb-3">
                                <i class="fas fa-map-pin me-1"></i>
                                @dest.Lat.ToString("0.00"), @dest.Lon.ToString("0.00")
                            </p>
                            @if (dest.Attractions != null && dest.Attractions.Any())
                            {
                                <p class="small text-success">
                                    <i class="fas fa-landmark me-1"></i>
                                    @dest.Attractions.Count attractions nearby
                                </p>
                            }
                            <a href="@Url.Action("ApiDetails", "Destinations", new { cityName = dest.Name })"
                                   class="btn btn-primary w-100 mt-2">
                                Explore <i class="fas fa-arrow-right ms-2"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="fas fa-map-marked-alt fa-4x text-muted mb-3"></i>
            <h3>No destinations found</h3>
            <p class="text-muted">Try searching a different city</p>
        </div>
    }
</div>

<style>
    .card {
        transition: transform 0.3s ease;
    }

        .card:hover {
            transform: translateY(-5px);
        }

    .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
    }
</style>
</style>