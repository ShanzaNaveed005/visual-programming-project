@model List<AITourismPlanner.Models.Destination>
@{
    ViewData["Title"] = "Explore Destinations";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var categories = ViewBag.Categories as List<AITourismPlanner.Models.Category>;
}

<div class="container py-4">
    <!-- Header -->
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Explore Destinations</h1>
        <p class="lead text-muted">Discover amazing places in Pakistan</p>
    </div>

    <!-- Filters -->
    <div class="card shadow-sm border-0 rounded-4 mb-5">
        <div class="card-body p-4">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <input type="text" name="searchTerm" class="form-control form-control-lg" 
                           placeholder="Search destinations..." value="@ViewBag.SearchTerm">
                </div>
                <div class="col-md-3">
                    <select name="category" class="form-select form-select-lg">
                        <option value="">All Categories</option>
                        @if (categories != null)
                        {
                            foreach (var cat in categories)
                            {
                                <option value="@cat.category_name" selected="@(ViewBag.SelectedCategory == cat.category_name)">
                                    @cat.category_name
                                </option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <input type="number" name="minBudget" class="form-control form-control-lg" placeholder="Min Budget">
                </div>
                <div class="col-md-2">
                    <input type="number" name="maxBudget" class="form-control form-control-lg" placeholder="Max Budget">
                </div>
                <div class="col-md-1">
                    <button type="submit" class="btn btn-primary btn-lg w-100">
                        <i class="fas fa-search"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Results Count -->
    <div class="mb-4">
        <p class="text-muted">Found <strong>@Model.Count</strong> destinations</p>
    </div>

    <!-- Destinations Grid -->
    <div class="row g-4">
        @foreach (var dest in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card destination-card h-100 shadow-sm border-0 rounded-4 overflow-hidden">
                    <div class="position-relative">
                        <img src="@(dest.thumbnail ?? "/images/default-destination.jpg")" 
                             class="card-img-top" style="height: 220px; object-fit: cover;" 
                             alt="@dest.name">
                        <div class="position-absolute top-0 end-0 m-3">
                            <span class="badge bg-warning text-dark px-3 py-2 rounded-pill">
                                <i class="fas fa-star text-warning"></i> @dest.rating_average.ToString("0.0")
                            </span>
                        </div>
                        @if (dest.estimated_cost <= 30000)
                        {
                            <span class="position-absolute top-0 start-0 m-3 badge bg-success">
                                <i class="fas fa-tag"></i> Budget Friendly
                            </span>
                        }
                    </div>
                    <div class="card-body p-4">
                        <h5 class="card-title fw-bold">@dest.name</h5>
                        <p class="card-text text-muted small">
                            <i class="fas fa-map-marker-alt text-primary"></i> @dest.city, @dest.country
                        </p>
                        <p class="card-text">@(dest.description?.Length > 100 ? dest.description.Substring(0, 100) + "..." : dest.description)</p>
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <span class="text-primary fw-bold fs-5">PKR @dest.estimated_cost?.ToString("N0")</span>
                            <span class="text-muted"><i class="fas fa-clock"></i> @dest.best_season</span>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-4 px-4">
                        <a href="@Url.Action("Details", new { id = dest.destination_id })" class="btn btn-primary w-100">
                            View Details <i class="fas fa-arrow-right ms-2"></i>
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-map-marked-alt fa-4x text-muted mb-3"></i>
            <h3>No destinations found</h3>
            <p class="text-muted">Try adjusting your search filters</p>
            <a href="@Url.Action("Index")" class="btn btn-primary">Clear Filters</a>
        </div>
    }
</div>

<style>
    .destination-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .destination-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.1) !important;
    }
    .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
    }
    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 20px rgba(102,126,234,0.4);
    }
</style>