@{
    ViewData["Title"] = "About Us";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="text-center mb-5">
                <h1 class="display-4 fw-bold">About AI Tourism Planner</h1>
                <p class="lead">Your Smart Travel Companion</p>
            </div>

            <div class="card shadow-lg border-0 rounded-4 mb-4">
                <div class="card-body p-4">
                    <h3 class="fw-bold"><i class="fas fa-robot text-primary me-2"></i> Our Mission</h3>
                    <p>To revolutionize travel planning using artificial intelligence, making it easier, smarter, and more personalized for every traveler.</p>
                </div>
            </div>

            <div class="card shadow-lg border-0 rounded-4 mb-4">
                <div class="card-body p-4">
                    <h3 class="fw-bold"><i class="fas fa-brain text-primary me-2"></i> AI Technology</h3>
                    <p>Our platform uses advanced AI algorithms to analyze your preferences, budget, and interests to recommend the perfect destinations and itineraries.</p>
                </div>
            </div>

            <div class="card shadow-lg border-0 rounded-4 mb-4">
                <div class="card-body p-4">
                    <h3 class="fw-bold"><i class="fas fa-star text-primary me-2"></i> Why Choose Us?</h3>
                    <ul class="list-unstyled">
                        <li><i class="fas fa-check-circle text-success me-2"></i> Smart AI-powered recommendations</li>
                        <li><i class="fas fa-check-circle text-success me-2"></i> Personalized trip planning</li>
                        <li><i class="fas fa-check-circle text-success me-2"></i> Best price guaranteed</li>
                        <li><i class="fas fa-check-circle text-success me-2"></i> 24/7 customer support</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>