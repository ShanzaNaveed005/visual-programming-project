@{
    ViewData["Title"] = "Contact Us";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="text-center mb-5">
                <h1 class="display-4 fw-bold">Contact Us</h1>
                <p class="lead">We'd love to hear from you!</p>
            </div>

            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-4">
                    <div class="row">
                        <div class="col-md-6">
                            <h4 class="fw-bold"><i class="fas fa-phone text-primary me-2"></i> Call Us</h4>
                            <p>+92 300 1234567<br>+92 300 7654321</p>
                            
                            <h4 class="fw-bold mt-4"><i class="fas fa-envelope text-primary me-2"></i> Email</h4>
                            <p>info@aitourism.com<br>support@aitourism.com</p>
                        </div>
                        <div class="col-md-6">
                            <h4 class="fw-bold"><i class="fas fa-map-marker-alt text-primary me-2"></i> Address</h4>
                            <p>AI Tourism Planner<br>IT Tower, Islamabad<br>Pakistan</p>
                            
                            <h4 class="fw-bold mt-4"><i class="fas fa-clock text-primary me-2"></i> Hours</h4>
                            <p>Monday - Friday: 9AM - 6PM<br>Saturday: 10AM - 4PM</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>