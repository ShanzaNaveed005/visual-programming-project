@using AITourismPlanner.ViewModels
@using System.Linq
@model HomeViewModel
@{
    ViewData["Title"] = "AI Tourism Planner - Smart Travel Companion";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Hero Section with Parallax -->
<section class="hero-section" style="background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('/images/hero-bg.jpg'); background-size: cover; background-position: center; height: 90vh; display: flex; align-items: center;">
    <div class="container text-center text-white">
        <h1 class="display-1 fw-bold">AI Tourism Planner</h1>
        <p class="lead fs-3 mt-3">Plan Your Dream Trip with Artificial Intelligence</p>
        <div class="mt-5">
            <a href="@Url.Action("Index", "Destinations")" class="btn btn-primary btn-lg mx-2 px-4 py-3">
                <i class="fas fa-search"></i> Explore Destinations
            </a>
            <a href="@Url.Action("PlanTrip", "Trips")" class="btn btn-outline-light btn-lg mx-2 px-4 py-3">
                <i class="fas fa-robot"></i> AI Trip Planner
            </a>
        </div>
    </div>
</section>

<!-- Search Bar Section -->
<section class="search-section py-4 bg-white shadow-sm">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-10">
                <form asp-action="Search" asp-controller="Destinations" method="get" class="row g-2">
                    <div class="col-md-4">
                        <input type="text" name="searchTerm" class="form-control form-control-lg" placeholder="Where to?">
                    </div>
                    <div class="col-md-3">
                        <select name="category" class="form-select form-select-lg">
                            <option value="">All Categories</option>
                            @if (Model.Categories != null && Model.Categories.Any())
                            {
                                @foreach (var cat in Model.Categories)
                                {
                                    <option value="@cat.category_name">@cat.category_name</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <input type="number" name="budget" class="form-control form-control-lg" placeholder="Max Budget (PKR)">
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary btn-lg w-100">
                            <i class="fas fa-search"></i> Search
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<!-- Popular Destinations -->
<section class="destinations-section py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold">Popular Destinations</h2>
            <p class="lead text-muted">Discover the most loved places by our travelers</p>
        </div>
        <div class="row g-4">
            @if (Model.PopularDestinations != null && Model.PopularDestinations.Any())
            {
                @foreach (var dest in Model.PopularDestinations)
                {
                    <div class="col-md-4 col-lg-4">
                        <div class="card destination-card h-100 shadow-lg border-0 rounded-4 overflow-hidden">
                            <div class="position-relative">
                                <!-- FIXED IMAGE TAG WITH PROPER PATH HANDLING -->
                                @{
                                    var imagePath = dest.thumbnail;
                                    if (string.IsNullOrEmpty(imagePath) || !imagePath.StartsWith("/images/"))
                                    {
                                        if (!string.IsNullOrEmpty(dest.name))
                                        {
                                            var nameLower = dest.name.ToLower();
                                            if (nameLower.Contains("hunza")) imagePath = "/images/hunza.jpg";
                                            else if (nameLower.Contains("murree")) imagePath = "/images/murree.jpg";
                                            else if (nameLower.Contains("skardu")) imagePath = "/images/skardu.jpg";
                                            else if (nameLower.Contains("swat")) imagePath = "/images/swat.jpg";
                                            else if (nameLower.Contains("naran")) imagePath = "/images/naran.jpg";
                                            else imagePath = "/images/default-destination.jpg";
                                        }
                                        else
                                        {
                                            imagePath = "/images/default-destination.jpg";
                                        }
                                    }
                                }
                                <img src="@imagePath" 
                                     class="card-img-top" 
                                     style="height: 250px; width: 100%; object-fit: cover;" 
                                     alt="@dest.name"
                                     onerror="this.onerror=null; this.src='/images/default-destination.jpg';">
                                <div class="position-absolute top-0 end-0 m-3">
                                    <span class="badge bg-warning text-dark px-3 py-2 rounded-pill">
                                        <i class="fas fa-star text-warning"></i> @dest.rating_average.ToString("0.0")
                                    </span>
                                </div>
                            </div>
                            <div class="card-body p-4">
                                <h5 class="card-title fw-bold">@dest.name</h5>
                                <p class="card-text text-muted">@(dest.description?.Length > 100 ? dest.description.Substring(0, 100) + "..." : dest.description)</p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="text-primary fw-bold fs-5">PKR @dest.estimated_cost?.ToString("N0")</span>
                                    <span class="text-muted"><i class="fas fa-map-marker-alt"></i> @(dest.city ?? "Pakistan")</span>
                                </div>
                            </div>
                            <div class="card-footer bg-transparent border-0 pb-4 px-4">
                                <a href="@Url.Action("Details", "Destinations", new { id = dest.destination_id })" class="btn btn-outline-primary w-100">
                                    View Details <i class="fas fa-arrow-right"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center">
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle fa-2x mb-2"></i>
                        <h4>No destinations found</h4>
                        <p>Please add destinations to your database.</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- AI Trip Planner CTA -->
<section class="ai-section py-5" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-7 text-white">
                <h2 class="display-4 fw-bold">Plan Your Trip with AI</h2>
                <p class="fs-4 mt-3">Tell us your budget, preferences, and let our AI suggest the perfect destination and itinerary for you.</p>
                <ul class="list-unstyled mt-4">
                    <li><i class="fas fa-check-circle me-2"></i> Smart destination recommendations</li>
                    <li><i class="fas fa-check-circle me-2"></i> Day-wise itinerary generator</li>
                    <li><i class="fas fa-check-circle me-2"></i> Budget optimization</li>
                    <li><i class="fas fa-check-circle me-2"></i> Real-time weather updates</li>
                </ul>
                <a href="@Url.Action("PlanTrip", "Trips")" class="btn btn-light btn-lg mt-4 px-5 py-3 fw-bold">
                    <i class="fas fa-magic"></i> Start AI Planning
                </a>
            </div>
            <div class="col-md-5 text-center">
                <img src="/images/ai-illustration.svg" alt="AI Planning" class="img-fluid" style="max-height: 350px;" onerror="this.style.display='none'">
            </div>
        </div>
    </div>
</section>

<!-- Featured Hotels -->
<section class="hotels-section py-5 bg-light">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold">Featured Hotels</h2>
            <p class="lead text-muted">Handpicked accommodations for you</p>
        </div>
        <div class="row g-4">
            @if (Model.FeaturedHotels != null && Model.FeaturedHotels.Any())
            {
                @foreach (var hotel in Model.FeaturedHotels)
                {
                    <div class="col-md-3 col-sm-6">
                        <div class="card hotel-card shadow-sm border-0 rounded-4 h-100">
                            @{
                                var hotelImage = hotel.image;
                                if (string.IsNullOrEmpty(hotelImage))
                                {
                                    hotelImage = "/images/hotel-default.jpg";
                                }
                            }
                            <img src="@hotelImage" 
                                 class="card-img-top rounded-top-4" 
                                 style="height: 180px; width: 100%; object-fit: cover;" 
                                 alt="@hotel.hotel_name"
                                 onerror="this.onerror=null; this.src='/images/hotel-default.jpg';">
                            <div class="card-body p-3">
                                <h6 class="card-title fw-bold">@hotel.hotel_name</h6>
                                <div class="mb-2">
                                    @for (int i = 1; i <= (hotel.star_rating ?? 0); i++)
                                    {
                                        <i class="fas fa-star text-warning small"></i>
                                    }
                                </div>
                                <p class="text-primary fw-bold">PKR @hotel.price_per_night?.ToString("N0")<span class="text-muted fw-normal">/night</span></p>
                                <a href="@Url.Action("Details", "Hotels", new { id = hotel.hotel_id })" class="btn btn-sm btn-outline-primary w-100">View Hotel</a>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>

<!-- Testimonials -->
<section class="testimonials-section py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold">What Travelers Say</h2>
            <p class="lead text-muted">Trusted by thousands of happy travelers</p>
        </div>
        <div class="row g-4">
            @if (Model.Testimonials != null && Model.Testimonials.Any())
            {
                @foreach (var review in Model.Testimonials)
                {
                    <div class="col-md-4">
                        <div class="card testimonial-card shadow-sm border-0 rounded-4 h-100">
                            <div class="card-body p-4">
                                <div class="mb-3">
                                    @for (int i = 1; i <= (review.rating ?? 0); i++)
                                    {
                                        <i class="fas fa-star text-warning"></i>
                                    }
                                </div>
                                <p class="card-text fs-5">"@(review.review_text?.Length > 150 ? review.review_text.Substring(0, 150) + "..." : review.review_text)"</p>
                                <div class="d-flex align-items-center mt-3">
                                    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px;">
                                        <span class="fw-bold">@(review.User?.full_name?.FirstOrDefault().ToString() ?? "U")</span>
                                    </div>
                                    <div>
                                        <h6 class="mb-0 fw-bold">@(review.User?.full_name ?? "Anonymous")</h6>
                                        <small class="text-muted">Visited @(review.Destination?.name ?? "a destination")</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>

<!-- Newsletter Section -->
<section class="newsletter-section py-5" style="background: #0a192f;">
    <div class="container text-center text-white">
        <h3 class="fw-bold">Subscribe to Our Newsletter</h3>
        <p class="mb-4">Get exclusive travel deals and AI planning tips</p>
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="input-group">
                    <input type="email" class="form-control form-control-lg" placeholder="Your email address">
                    <button class="btn btn-primary btn-lg" type="button">Subscribe</button>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .destination-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .destination-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 1rem 3rem rgba(0,0,0,.175) !important;
    }
    .testimonial-card {
        transition: all 0.3s ease;
    }
    .testimonial-card:hover {
        transform: scale(1.02);
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
    }
    .search-section {
        margin-top: -30px;
        position: relative;
        z-index: 1000;
    }
    .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
    }
    .btn-primary:hover {
        background: linear-gradient(135deg, #5a67d8 0%, #6b46a0 100%);
        transform: translateY(-2px);
    }
    /* Ensure images are always visible */
    img {
        display: block !important;
        visibility: visible !important;
        opacity: 1 !important;
    }
    .card-img-top {
        min-height: 250px;
        background-color: #f0f0f0;
    }
</style>