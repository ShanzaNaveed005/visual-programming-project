@model List<AITourismPlanner.Models.HotelBooking>
@{
    ViewData["Title"] = "My Hotel Bookings";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <h1 class="display-5 fw-bold mb-4">
        <i class="fas fa-hotel text-primary"></i> My Hotel Bookings
    </h1>

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var booking in Model)
            {
                <div class="col-md-6">
                    <div class="card shadow-sm border-0 rounded-4">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h5 class="fw-bold">@booking.Hotel?.hotel_name</h5>
                                    <p class="text-muted small">
                                        <i class="fas fa-map-marker-alt me-1"></i> @booking.Hotel?.address
                                    </p>
                                </div>
                                <span class="badge @(booking.booking_status == "Confirmed" ? "bg-success" : booking.booking_status == "Pending" ? "bg-warning" : "bg-danger")">
                                    @booking.booking_status
                                </span>
                            </div>
                            
                            <hr>
                            
                            <div class="row">
                                <div class="col-6">
                                    <small class="text-muted">Check In</small>
                                    <p class="fw-bold">@booking.check_in?.ToString("dd MMM yyyy")</p>
                                </div>
                                <div class="col-6">
                                    <small class="text-muted">Check Out</small>
                                    <p class="fw-bold">@booking.check_out?.ToString("dd MMM yyyy")</p>
                                </div>
                            </div>
                            
                            <div class="row">
                                <div class="col-6">
                                    <small class="text-muted">Room Type</small>
                                    <p class="fw-bold">@booking.HotelRoom?.room_type</p>
                                </div>
                                <div class="col-6">
                                    <small class="text-muted">Total Amount</small>
                                    <p class="fw-bold text-primary">PKR @booking.total_amount?.ToString("N0")</p>
                                </div>
                            </div>
                            
                            @if (booking.booking_status == "Pending")
                            {
                                <div class="mt-3">
                                    <a href="@Url.Action("MakePayment", "Payments", new { bookingId = booking.booking_id, bookingType = "Hotel", amount = booking.total_amount })"
                                           class="btn btn-success btn-sm me-2">
                                        <i class="fas fa-credit-card"></i> Pay Now
                                    </a>
                                    <button onclick="cancelBooking(@booking.booking_id)" class="btn btn-danger btn-sm">
                                        <i class="fas fa-times"></i> Cancel
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="fas fa-hotel fa-4x text-muted mb-3"></i>
            <h3>No bookings yet</h3>
            <a href="@Url.Action("Search", "HotelBooking")" class="btn btn-primary">Search Hotels</a>
        </div>
    }
</div>

<script>
    function cancelBooking(bookingId) {
        if (confirm('Are you sure you want to cancel this booking?')) {
            $.ajax({
                url: '@Url.Action("CancelBooking", "HotelBooking")',
                type: 'POST',
                data: { id: bookingId },
                headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                success: function(response) {
                    if (response.success) {
                        alert(response.message);
                        location.reload();
                    } else {
                        alert(response.message);
                    }
                }
            });
        }
    }
</script>