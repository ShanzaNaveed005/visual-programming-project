@{
    ViewData["Title"] = "Hotel Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-5 text-center">
                    <i class="fas fa-hotel fa-5x text-primary mb-4"></i>
                    <h1 class="display-5 fw-bold">Hotel Details</h1>
                    <p class="lead">Hotel ID: @ViewBag.Id</p>
                    <p class="text-muted">This feature is coming soon!</p>
                    <a href="@Url.Action("Index", "Hotels")" class="btn btn-primary mt-3">
                        <i class="fas fa-arrow-left"></i> Back to Hotels
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>