@{
    ViewData["Title"] = "Hotels";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">
            <i class="fas fa-hotel text-primary"></i> Find Your Perfect Stay
        </h1>
        <p class="lead">Discover the best hotels across Pakistan</p>
    </div>

    <!-- Search Form -->
    <div class="card shadow-lg border-0 rounded-4 mb-5">
        <div class="card-body p-4">
            <form method="get" action="@Url.Action("Search", "HotelBooking")" class="row g-3">
                <div class="col-md-5">
                    <label class="form-label fw-bold">Destination</label>
                    <input type="text" name="city" class="form-control form-control-lg" placeholder="Enter city (e.g., Murree, Hunza)">
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Check In</label>
                    <input type="date" name="checkIn" class="form-control form-control-lg" value="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")">
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Check Out</label>
                    <input type="date" name="checkOut" class="form-control form-control-lg" value="@DateTime.Now.AddDays(3).ToString("yyyy-MM-dd")">
                </div>
                <div class="col-md-1">
                    <label class="form-label fw-bold">&nbsp;</label>
                    <button type="submit" class="btn btn-primary btn-lg w-100">
                        <i class="fas fa-search"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Popular Destinations -->
    <div class="text-center mb-4">
        <h3 class="fw-bold">Popular Hotel Destinations</h3>
    </div>
    
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 text-center">
                <div class="card-body p-4">
                    <i class="fas fa-mountain fa-3x text-primary mb-3"></i>
                    <h4>Murree</h4>
                    <p class="text-muted">10+ Hotels</p>
                    <a href="@Url.Action("Search", "HotelBooking", new { city = "Murree" })" class="btn btn-outline-primary">View Hotels</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 text-center">
                <div class="card-body p-4">
                    <i class="fas fa-mountain-city fa-3x text-primary mb-3"></i>
                    <h4>Hunza</h4>
                    <p class="text-muted">15+ Hotels</p>
                    <a href="@Url.Action("Search", "HotelBooking", new { city = "Hunza" })" class="btn btn-outline-primary">View Hotels</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 text-center">
                <div class="card-body p-4">
                    <i class="fas fa-water fa-3x text-primary mb-3"></i>
                    <h4>Skardu</h4>
                    <p class="text-muted">8+ Hotels</p>
                    <a href="@Url.Action("Search", "HotelBooking", new { city = "Skardu" })" class="btn btn-outline-primary">View Hotels</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Features -->
    <div class="row mt-5 text-center">
        <div class="col-md-4">
            <div class="card border-0 bg-light rounded-4">
                <div class="card-body p-4">
                    <i class="fas fa-tag fa-2x text-primary mb-2"></i>
                    <h5>Best Price Guarantee</h5>
                    <small class="text-muted">We offer competitive rates</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 bg-light rounded-4">
                <div class="card-body p-4">
                    <i class="fas fa-headset fa-2x text-primary mb-2"></i>
                    <h5>24/7 Support</h5>
                    <small class="text-muted">We're here to help</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 bg-light rounded-4">
                <div class="card-body p-4">
                    <i class="fas fa-check-circle fa-2x text-primary mb-2"></i>
                    <h5>Secure Booking</h5>
                    <small class="text-muted">Your payments are safe</small>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
    }
    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 20px rgba(102,126,234,0.4);
    }
    .card {
        transition: transform 0.3s ease;
    }
    .card:hover {
        transform: translateY(-5px);
    }
</style>