@model List<AITourismPlanner.Controllers.HotelResult>
@{
    ViewData["Title"] = "Search Hotels";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <!-- Search Form -->
    <div class="card shadow-lg border-0 rounded-4 mb-5">
        <div class="card-body p-4">
            <h3 class="fw-bold mb-4">
                <i class="fas fa-search text-primary"></i> Find Hotels
            </h3>
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label fw-bold">City</label>
                    <input type="text" name="city" class="form-control form-control-lg"
                           value="@ViewBag.City" placeholder="e.g., Islamabad, Lahore">
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Check In</label>
                    <input type="date" name="checkIn" class="form-control form-control-lg"
                           value="@ViewBag.CheckIn">
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Check Out</label>
                    <input type="date" name="checkOut" class="form-control form-control-lg"
                           value="@ViewBag.CheckOut">
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-bold">Guests</label>
                    <input type="number" name="guests" class="form-control form-control-lg"
                           value="@ViewBag.Guests" min="1" max="10">
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-primary btn-lg w-100">
                        <i class="fas fa-search me-2"></i> Search Hotels
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Results -->
    @if (Model != null && Model.Any())
    {
        <h4 class="mb-4">Found <strong>@Model.Count</strong> hotels</h4>
        <div class="row g-4">
            @foreach (var hotel in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0 rounded-4">
                        @if (!string.IsNullOrEmpty(hotel.ImageUrl))
                        {
                            <img src="@hotel.ImageUrl" class="card-img-top rounded-top-4"
                                 style="height: 200px; object-fit: cover;" alt="@hotel.Name">
                        }
                        else
                        {
                            <div class="rounded-top-4" style="height: 200px;
                                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                                display: flex; align-items: center; justify-content: center;">
                                <i class="fas fa-hotel fa-4x text-white"></i>
                            </div>
                        }
                        <div class="card-body p-4">
                            <h5 class="card-title fw-bold">@hotel.Name</h5>
                            <p class="text-muted small">
                                <i class="fas fa-map-marker-alt me-1"></i> @hotel.Address
                            </p>
                            @if (hotel.Rating.HasValue)
                            {
                                <p>
                                    <i class="fas fa-star text-warning"></i>
                                    <strong>@hotel.Rating?.ToString("0.0")</strong>
                                    @if (hotel.ReviewCount.HasValue)
                                    {
                                        <span class="text-muted small">
                                            (@hotel.ReviewCount reviews)
                                        </span>
                                    }
                                </p>
                            }
                            @if (hotel.PricePerNight.HasValue)
                            {
                                <p class="text-primary fw-bold fs-5">
                                    PKR @hotel.PricePerNight?.ToString("N0")
                                    <span class="text-muted fw-normal fs-6">/night</span>
                                </p>
                            }
                            else
                            {
                                <p class="text-muted">Price not available</p>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="fas fa-hotel fa-4x text-muted mb-3"></i>
            <h3>No hotels found</h3>
            <p class="text-muted">Try a different city or dates</p>
        </div>
    }
</div>

<style>
    .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(102,126,234,0.4);
        }

    .card {
        transition: transform 0.3s ease;
    }

        .card:hover {
            transform: translateY(-5px);
        }
</style>