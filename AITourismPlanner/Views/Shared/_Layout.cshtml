<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AI Tourism Planner</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Animate.css -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css">

    <!-- Custom CSS -->
    <style>
            * {
                font-family: 'Poppins', sans-serif;
            }

            body {
                overflow-x: hidden;
            }

            .navbar {
                background: white;
                box-shadow: 0 2px 20px rgba(0,0,0,0.1);
                padding: 1rem 0;
                transition: all 0.3s ease;
            }

            .navbar-scrolled {
                background: rgba(255,255,255,0.95) !important;
                backdrop-filter: blur(10px);
                box-shadow: 0 5px 30px rgba(0,0,0,0.1);
            }

            .nav-link {
                font-weight: 500;
                color: #333 !important;
                transition: all 0.3s ease;
                margin: 0 0.5rem;
            }

                .nav-link:hover {
                    color: #667eea !important;
                    transform: translateY(-2px);
                }

            .dropdown-menu {
                border: none;
                box-shadow: 0 10px 30px rgba(0,0,0,0.1);
                border-radius: 15px;
                padding: 0.5rem 0;
            }

            .dropdown-item {
                padding: 0.7rem 1.5rem;
                transition: all 0.3s ease;
            }

                .dropdown-item:hover {
                    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                    color: white;
                    transform: translateX(5px);
                }

            .footer {
                background: #0a192f;
                color: white;
                padding: 4rem 0 2rem;
            }

                .footer a {
                    color: #aaa;
                    text-decoration: none;
                    transition: all 0.3s ease;
                }

                    .footer a:hover {
                        color: #667eea;
                        transform: translateX(5px);
                    }

            .btn-gradient {
                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                color: white;
                border: none;
                transition: all 0.3s ease;
            }

                .btn-gradient:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 5px 20px rgba(102,126,234,0.4);
                    color: white;
                }

            .toast-notification {
                position: fixed;
                bottom: 20px;
                right: 20px;
                z-index: 9999;
            }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Navigation Bar -->
    <nav class="navbar navbar-expand-lg fixed-top" id="mainNav">
        <div class="container">
            <a class="navbar-brand fw-bold fs-3" href="@Url.Action("Index", "Home")">
                <i class="fas fa-robot text-primary"></i> AI Tourism
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Index", "Home")">
                            <i class="fas fa-home"></i> Home
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Index", "Destinations")">
                            <i class="fas fa-map-marked-alt"></i> Destinations
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("PlanTrip", "Trips")">
                            <i class="fas fa-robot"></i> AI Trip Planner
                        </a>
                    </li>
                    
                    <!-- Weather Link -->
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Index", "Weather")">
                            <i class="fas fa-cloud-sun"></i> Weather
                        </a>
                    </li>
                    
                    <!-- Transport Link -->
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Search", "Transport")">
                            <i class="fas fa-bus"></i> Transport
                        </a>
                    </li>
                    
                    <!-- Real Hotels Link -->
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Search", "RealHotels")">
                            <i class="fas fa-globe"></i> Real Hotels
                        </a>
                    </li>
                    
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            <i class="fas fa-briefcase"></i> Services
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="@Url.Action("Index", "Hotels")"><i class="fas fa-hotel"></i> Hotels</a></li>
                            <li><a class="dropdown-item" href="@Url.Action("Search", "RealHotels")"><i class="fas fa-globe"></i> Real Hotels (API)</a></li>
                            <li><a class="dropdown-item" href="@Url.Action("Search", "Transport")"><i class="fas fa-bus"></i> Transport</a></li>
                            <li><a class="dropdown-item" href="@Url.Action("Index", "Chatbot")"><i class="fas fa-comment-dots"></i> AI Chatbot</a></li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("About", "Home")">
                            <i class="fas fa-info-circle"></i> About
                        </a>
                    </li>
                </ul>

                <ul class="navbar-nav">
                    @{
                        var userId = Context.Session.GetInt32("UserId");
                        var userName = Context.Session.GetString("UserName");
                    }
                    @if (userId.HasValue)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-user-circle"></i> @userName
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="@Url.Action("Dashboard", "Account")"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
                                <li><a class="dropdown-item" href="@Url.Action("MyTrips", "Trips")"><i class="fas fa-plane"></i> My Trips</a></li>
                                <li><a class="dropdown-item" href="@Url.Action("MyBookings", "HotelBooking")"><i class="fas fa-ticket-alt"></i> My Bookings</a></li>
                                <li><a class="dropdown-item" href="@Url.Action("Wishlist", "Account")"><i class="fas fa-heart"></i> Favorites</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="@Url.Action("Logout", "Account")"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Login", "Account")">
                                <i class="fas fa-sign-in-alt"></i> Login
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-gradient ms-2" href="@Url.Action("Register", "Account")">
                                <i class="fas fa-user-plus"></i> Sign Up
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main style="margin-top: 76px;">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-4">
                    <h4 class="fw-bold mb-3"><i class="fas fa-robot text-primary"></i> AI Tourism Planner</h4>
                    <p>Plan your perfect trip using artificial intelligence. Get personalized recommendations, smart itineraries, and best deals.</p>
                    <div class="mt-3">
                        <a href="#" class="me-3"><i class="fab fa-facebook fa-lg"></i></a>
                        <a href="#" class="me-3"><i class="fab fa-twitter fa-lg"></i></a>
                        <a href="#" class="me-3"><i class="fab fa-instagram fa-lg"></i></a>
                        <a href="#"><i class="fab fa-linkedin fa-lg"></i></a>
                    </div>
                </div>
                <div class="col-md-2 mb-4">
                    <h5>Quick Links</h5>
                    <ul class="list-unstyled">
                        <li><a href="@Url.Action("Index", "Home")">Home</a></li>
                        <li><a href="@Url.Action("Index", "Destinations")">Destinations</a></li>
                        <li><a href="@Url.Action("PlanTrip", "Trips")">AI Planner</a></li>
                        <li><a href="@Url.Action("Index", "Weather")">Weather</a></li>
                        <li><a href="@Url.Action("Search", "Transport")">Transport</a></li>
                        <li><a href="@Url.Action("Search", "RealHotels")">Real Hotels</a></li>
                        <li><a href="@Url.Action("About", "Home")">About Us</a></li>
                    </ul>
                </div>
                <div class="col-md-3 mb-4">
                    <h5>Support</h5>
                    <ul class="list-unstyled">
                        <li><a href="#">Help Center</a></li>
                        <li><a href="#">Terms & Conditions</a></li>
                        <li><a href="#">Privacy Policy</a></li>
                        <li><a href="@Url.Action("Contact", "Home")">Contact Us</a></li>
                    </ul>
                </div>
                <div class="col-md-3 mb-4">
                    <h5>Contact Info</h5>
                    <ul class="list-unstyled">
                        <li><i class="fas fa-phone me-2"></i> +92 300 1234567</li>
                        <li><i class="fas fa-envelope me-2"></i> info@aitourism.com</li>
                        <li><i class="fas fa-map-marker-alt me-2"></i> Islamabad, Pakistan</li>
                    </ul>
                </div>
            </div>
            <hr class="mt-4">
            <div class="text-center">
                <p class="mb-0">&copy; 2025 AI Tourism Planner. All rights reserved. Powered by Artificial Intelligence.</p>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        window.addEventListener('scroll', function() {
        if (window.scrollY > 50) {
        document.getElementById('mainNav').classList.add('navbar-scrolled');
        } else {
        document.getElementById('mainNav').classList.remove('navbar-scrolled');
        }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>