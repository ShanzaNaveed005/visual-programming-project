@model AITourismPlanner.Controllers.TransportBookingViewModel
@{
    ViewData["Title"] = "Book Transport";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-gradient-primary text-white text-center py-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                    <i class="fas fa-ticket-alt fa-3x mb-2"></i>
                    <h2 class="mb-0">Confirm Booking</h2>
                </div>
                <div class="card-body p-4">
                    <!-- Journey Summary -->
                    <div class="bg-light rounded-4 p-3 mb-4">
                        <div class="row">
                            <div class="col-6">
                                <small class="text-muted">From</small>
                                <p class="fw-bold mb-0">@Model.Transport?.departure_city</p>
                            </div>
                            <div class="col-6">
                                <small class="text-muted">To</small>
                                <p class="fw-bold mb-0">@Model.Transport?.arrival_city</p>
                            </div>
                            <div class="col-6 mt-2">
                                <small class="text-muted">Date</small>
                                <p class="fw-bold mb-0">@Model.JourneyDate.ToString("dd MMM yyyy")</p>
                            </div>
                            <div class="col-6 mt-2">
                                <small class="text-muted">Departure Time</small>
                                <p class="fw-bold mb-0">@Model.Transport?.departure_time.ToString(@"hh\:mm tt")</p>
                            </div>
                            <div class="col-6 mt-2">
                                <small class="text-muted">Company</small>
                                <p class="fw-bold mb-0">@Model.Transport?.company_name</p>
                            </div>
                            <div class="col-6 mt-2">
                                <small class="text-muted">Available Seats</small>
                                <p class="fw-bold mb-0 text-success">@Model.AvailableSeats seats</p>
                            </div>
                        </div>
                    </div>

                    <!-- Booking Form -->
                    <form asp-action="Book" method="post">
                        @Html.AntiForgeryToken()
                        
                        <input type="hidden" asp-for="TransportId" />
                        <input type="hidden" asp-for="JourneyDate" />
                        <input type="hidden" asp-for="Fare" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Seats" class="form-label fw-bold">Number of Seats</label>
                                <select asp-for="Seats" class="form-select" id="seatSelect">
                                    @for (int i = 1; i <= Math.Min(Model.AvailableSeats, 10); i++)
                                    {
                                        <option value="@i">@i Seat(s) - PKR @(Model.Fare * i).ToString("N0")</option>
                                    }
                                </select>
                                <span asp-validation-for="Seats" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Total Price</label>
                                <h3 class="text-primary" id="totalPrice">PKR @Model.TotalPrice.ToString("N0")</h3>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PassengerName" class="form-label fw-bold">Passenger Name</label>
                            <input asp-for="PassengerName" class="form-control" placeholder="Full name as per ID" required>
                                <span asp-validation-for="PassengerName" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="PassengerPhone" class="form-label fw-bold">Phone Number</label>
                                <input asp-for="PassengerPhone" class="form-control" placeholder="03XXXXXXXXX" required>
                                    <span asp-validation-for="PassengerPhone" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="PassengerEmail" class="form-label fw-bold">Email Address</label>
                                    <input asp-for="PassengerEmail" type="email" class="form-control" placeholder="your@email.com" required>
                                        <span asp-validation-for="PassengerEmail" class="text-danger"></span>
                                    </div>

                                    <div class="alert alert-info">
                                        <i class="fas fa-info-circle"></i> Booking confirmation will be sent to your email and phone.
                                    </div>

                                    <button type="submit" class="btn btn-primary btn-lg w-100">
                                        <i class="fas fa-check-circle"></i> Confirm Booking
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <script>
                document.getElementById('seatSelect').addEventListener('change', function() {
                    var seats = this.value;
                    var fare = @Model.Fare;
                    var total = seats * fare;
                    document.getElementById('totalPrice').innerText = 'PKR ' + total.toLocaleString();
                });
            </script>

            <style>
                .btn-primary {
                    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                    border: none;
                }
            </style>