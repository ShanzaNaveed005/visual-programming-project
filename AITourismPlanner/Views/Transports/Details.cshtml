@model AITourismPlanner.Models.Transport
@{
    ViewData["Title"] = "Transport Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header bg-gradient-primary text-white text-center py-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
            <i class="fas fa-@(Model.transport_type == "Bus" ? "bus" : Model.transport_type == "Train" ? "train" : "plane") fa-3x mb-2"></i>
            <h2 class="mb-0">@Model.company_name</h2>
            <p class="mb-0">@Model.transport_type</p>
        </div>
        <div class="card-body p-4">
            <div class="row">
                <div class="col-md-6">
                    <h5 class="fw-bold">Journey Details</h5>
                    <table class="table table-borderless">
                        <tr>
                            <td><i class="fas fa-map-marker-alt text-primary"></i> From</td>
                            <td class="fw-bold">@Model.departure_city</td>
                        </tr>
                        <tr>
                            <td><i class="fas fa-flag-checkered text-primary"></i> To</td>
                            <td class="fw-bold">@Model.arrival_city</td>
                        </tr>
                        <tr>
                            <td><i class="fas fa-clock text-primary"></i> Departure</td>
                            <td class="fw-bold">@Model.departure_time.ToString(@"hh\:mm tt")</td>
                        </tr>
                        <tr>
                            <td><i class="fas fa-hourglass-half text-primary"></i> Duration</td>
                            <td class="fw-bold">@Model.duration</td>
                        </tr>
                        <tr>
                            <td><i class="fas fa-clock text-primary"></i> Arrival</td>
                            <td class="fw-bold">@Model.arrival_time.ToString(@"hh\:mm tt")</td>
                        </tr>
                    </table>
                </div>
                <div class="col-md-6">
                    <h5 class="fw-bold">Fare & Availability</h5>
                    <table class="table table-borderless">
                        <tr>
                            <td><i class="fas fa-money-bill-wave text-primary"></i> Fare per person</td>
                            <td class="fw-bold text-primary fs-4">PKR @Model.fare.ToString("N0")</td>
                        </tr>
                        <tr>
                            <td><i class="fas fa-chair text-primary"></i> Available Seats</td>
                            <td class="fw-bold">
                                @{
                                    var available = ViewBag.AvailableSeats;
                                    if (available > 0)
                                    {
                                        <span class="text-success">@available seats available</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger">No seats available</span>
                                    }
                                }
                            </td>
                        </tr>
                        <tr>
                            <td><i class="fas fa-calendar-alt text-primary"></i> Journey Date</td>
                            <td class="fw-bold">@ViewBag.JourneyDate?.ToString("dd MMM yyyy")</td>
                        </tr>
                    </table>
                </div>
            </div>

            <hr>

            <h5 class="fw-bold"><i class="fas fa-gift text-primary"></i> Amenities</h5>
            <div class="row">
                @if (!string.IsNullOrEmpty(Model.amenities))
                {
                    foreach (var amenity in Model.amenities.Split(','))
                    {
                        <div class="col-md-3">
                            <p><i class="fas fa-check-circle text-success"></i> @amenity.Trim()</p>
                        </div>
                    }
                }
            </div>

            <div class="mt-4 text-center">
                @if (ViewBag.AvailableSeats > 0)
                {
                    <a href="@Url.Action("Book", "Transport", new { id = Model.transport_id, date = ViewBag.JourneyDate })" class="btn btn-primary btn-lg px-5">
                        <i class="fas fa-ticket-alt"></i> Book Now
                    </a>
                }
                else
                {
                    <button class="btn btn-secondary btn-lg px-5" disabled>
                        <i class="fas fa-ban"></i> Sold Out
                    </button>
                }
                <a href="@Url.Action("Search", "Transport")" class="btn btn-outline-secondary btn-lg px-5">
                    <i class="fas fa-search"></i> Search Again
                </a>
            </div>
        </div>
    </div>
</div>