@model List<AITourismPlanner.Models.Trip>
@{
    ViewData["Title"] = "My Trips";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var userId = Context.Session.GetInt32("UserId");
}

@if (!userId.HasValue)
{
    <div class="container py-5">
        <div class="alert alert-warning text-center">
            <i class="fas fa-exclamation-triangle fa-2x mb-2"></i>
            <h4>Please Login First</h4>
            <a href="@Url.Action("Login", "Account")" class="btn btn-primary">Login Now</a>
        </div>
    </div>
    return;
}

<div class="container py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-5 fw-bold">
                <i class="fas fa-plane text-primary"></i> My Trips
            </h1>
            <p class="text-muted">Your travel history and upcoming adventures</p>
        </div>
        <div>
            <a href="@Url.Action("PlanTrip", "Trips")" class="btn btn-primary btn-lg">
                <i class="fas fa-plus"></i> Plan New Trip
            </a>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var trip in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0 rounded-4">
                        <div class="card-img-top rounded-top-4" style="height: 160px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); display: flex; align-items: center; justify-content: center;">
                            <i class="fas fa-map-marked-alt fa-4x text-white"></i>
                        </div>
                        <div class="card-body p-4">
                            <h5 class="card-title fw-bold">@trip.Destination?.name</h5>
                            <p class="card-text text-muted small">
                                <i class="fas fa-calendar-alt me-1"></i> @trip.start_date?.ToString("dd MMM yyyy") - @trip.end_date?.ToString("dd MMM yyyy")
                            </p>
                            <p class="card-text">
                                <span class="badge bg-primary">@trip.total_days Days</span>
                                <span class="badge bg-success ms-2">PKR @trip.total_budget?.ToString("N0")</span>
                            </p>
                            <p class="card-text small text-muted">
                                <i class="fas fa-clock me-1"></i> Planned on @trip.created_at.ToString("dd MMM yyyy")
                            </p>
                        </div>
                        <div class="card-footer bg-transparent border-0 pb-4 px-4">
                            <div class="d-flex gap-2">
                                <a href="@Url.Action("Details", "Trips", new { id = trip.trip_id })" class="btn btn-outline-primary flex-grow-1">
                                    <i class="fas fa-eye"></i> View Details
                                </a>
                                <button onclick="deleteTrip(@trip.trip_id)" class="btn btn-outline-danger">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <div class="card shadow-sm border-0 rounded-4 bg-light">
                <div class="card-body p-5">
                    <i class="fas fa-suitcase fa-4x text-muted mb-3"></i>
                    <h3>No Trips Yet</h3>
                    <p class="text-muted">Start planning your first adventure with our AI Trip Planner!</p>
                    <a href="@Url.Action("PlanTrip", "Trips")" class="btn btn-primary btn-lg mt-3">
                        <i class="fas fa-robot me-2"></i> Plan Your First Trip
                    </a>
                </div>
            </div>
        </div>
    }
</div>

<form id="deleteForm" asp-action="Delete" method="post" style="display:none;">
    <input type="hidden" name="id" id="deleteId" />
    @Html.AntiForgeryToken()
</form>

<script>
    function deleteTrip(tripId) {
        if (confirm('Are you sure you want to delete this trip?')) {
            document.getElementById('deleteId').value = tripId;
            document.getElementById('deleteForm').submit();
        }
    }
</script>

<style>
    .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(102,126,234,0.4);
        }

    .card {
        transition: transform 0.3s ease;
    }

        .card:hover {
            transform: translateY(-5px);
        }
</style>