@model AITourismPlanner.Controllers.WeatherViewModel
@{
    ViewData["Title"] = "Weather Forecast";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">
            <i class="fas fa-cloud-sun text-primary"></i> Weather Forecast
        </h1>
        <p class="lead">Real-time weather data for your travel destinations</p>
    </div>

    <!-- Search Form -->
    <div class="card shadow-lg border-0 rounded-4 mb-5">
        <div class="card-body p-4">
            <form method="get" class="row g-3">
                <div class="col-md-8">
                    <label class="form-label fw-bold">City Name</label>
                    <input type="text" name="city" class="form-control form-control-lg" 
                           value="@ViewBag.City" placeholder="e.g., Islamabad, Lahore, Karachi, Murree">
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">&nbsp;</label>
                    <button type="submit" class="btn btn-primary btn-lg w-100">
                        <i class="fas fa-search"></i> Get Weather
                    </button>
                </div>
            </form>
        </div>
    </div>

    @if (Model?.CurrentWeather != null)
    {
        <!-- Current Weather -->
        <div class="card shadow-lg border-0 rounded-4 mb-5 overflow-hidden">
            <div class="card-header text-white text-center py-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                <h2 class="mb-0">Current Weather in @Model.CurrentWeather.City, @Model.CurrentWeather.Country</h2>
                <p class="mb-0 mt-2">@Model.CurrentWeather.LastUpdated.ToString("dd MMM yyyy, hh:mm tt")</p>
            </div>
            <div class="card-body p-4">
                <div class="row text-center">
                    <div class="col-md-4">
                        @if (!string.IsNullOrEmpty(Model.CurrentWeather.Icon))
                        {
                            <img src="@Model.CurrentWeather.Icon" alt="@Model.CurrentWeather.Condition" style="width: 100px;">
                        }
                        else
                        {
                            <i class="fas fa-cloud-sun fa-4x text-primary"></i>
                        }
                        <h3 class="mt-2">@Model.CurrentWeather.Temperature.ToString("0")°C</h3>
                        <p class="text-muted">Feels like @Model.CurrentWeather.FeelsLike.ToString("0")°C</p>
                    </div>
                    <div class="col-md-4">
                        <h5 class="fw-bold">@Model.CurrentWeather.Condition</h5>
                        <p class="text-muted">@Model.CurrentWeather.Description</p>
                        <div class="mt-3">
                            <p><i class="fas fa-tint"></i> Humidity: @Model.CurrentWeather.Humidity%</p>
                            <p><i class="fas fa-wind"></i> Wind: @Model.CurrentWeather.WindSpeed km/h</p>
                            <p><i class="fas fa-chart-line"></i> Pressure: @Model.CurrentWeather.Pressure hPa</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="bg-light rounded-4 p-3">
                            <p class="mb-1"><i class="fas fa-arrow-up"></i> Max: @Model.CurrentWeather.TempMax.ToString("0")°C</p>
                            <p class="mb-1"><i class="fas fa-arrow-down"></i> Min: @Model.CurrentWeather.TempMin.ToString("0")°C</p>
                            <hr>
                            <small class="text-muted">Powered by OpenWeatherMap</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 5-Day Forecast -->
        @if (Model.Forecast?.DailyForecasts != null && Model.Forecast.DailyForecasts.Any())
        {
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-white border-0 pt-4">
                    <h3 class="fw-bold">
                        <i class="fas fa-calendar-week text-primary"></i> 5-Day Forecast
                    </h3>
                </div>
                <div class="card-body">
                    <div class="row g-4">
                        @foreach (var day in Model.Forecast.DailyForecasts.Take(5))
                        {
                            <div class="col-md-2 col-sm-4 col-6">
                                <div class="card border-0 shadow-sm rounded-4 text-center">
                                    <div class="card-body p-3">
                                        <h6 class="fw-bold">@day.Date.ToString("ddd, dd MMM")</h6>
                                        @if (!string.IsNullOrEmpty(day.Icon))
                                        {
                                            <img src="@day.Icon" alt="@day.Condition" style="width: 50px;">
                                        }
                                        else
                                        {
                                            <i class="fas fa-cloud fa-2x text-primary"></i>
                                        }
                                        <h5 class="mt-2 mb-0">@day.TempMax.ToString("0")°C</h5>
                                        <small class="text-muted">@day.TempMin.ToString("0")°C</small>
                                        <p class="small mt-2 mb-0 text-muted">@day.Condition</p>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="alert alert-warning text-center">
            <i class="fas fa-exclamation-triangle fa-2x mb-2"></i>
            <h4>No weather data found</h4>
            <p>Please enter a valid city name (e.g., Islamabad, Lahore, Karachi)</p>
        </div>
    }
</div>

<style>
    .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
    }
    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 20px rgba(102,126,234,0.4);
    }
    .card {
        transition: transform 0.3s ease;
    }
    .card:hover {
        transform: translateY(-3px);
    }
</style>